{
  "name": "standup-autobot",
  "displayName": "Standup Autobot",
  "description": "Silently tracks developer activity and generates daily standup summaries using local LLMs.",
  "version": "0.0.1",
  "publisher": "devansh-kaila-006",
  "license": "SEE LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/devansh-kaila-006/standup-autobot"
  },
  "keywords": [
    "standup",
    "productivity",
    "ai",
    "gemini",
    "tracking"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onWebviewPanel:standupAutobot.dashboard"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Standup Autobot",
      "properties": {
        "standup.triggerTime": {
          "type": "string",
          "default": "09:00",
          "description": "Daily time to trigger standup summary generation (HH:MM)"
        },
        "standup.activityDuration": {
          "type": "integer",
          "default": 24,
          "description": "Number of hours of activity to include in the summary"
        },
        "standup.customPrompt": {
          "type": "string",
          "default": "",
          "description": "Additional instructions to append to the Gemini prompt (e.g., 'Mention JIRA tickets')"
        },
        "standup.tone": {
          "type": "string",
          "enum": [
            "brief",
            "detailed",
            "casual",
            "formal"
          ],
          "default": "casual",
          "description": "The tone of the generated standup summary"
        },
        "standup.outputLanguage": {
          "type": "string",
          "default": "English",
          "description": "The language in which the summary should be generated"
        },
        "standup.notionPageId": {
          "type": "string",
          "default": "",
          "description": "The Notion Page ID where standups should be appended"
        },
        "standup.jiraDomain": {
          "type": "string",
          "default": "",
          "description": "Your Jira domain (e.g., 'company' for company.atlassian.net)"
        },
        "standup.jiraEmail": {
          "type": "string",
          "default": "",
          "description": "Email for Jira API authentication"
        },
        "standup.jiraIssueKey": {
          "type": "string",
          "default": "",
          "description": "Default Jira Issue Key to post comments to (can be overridden during export)"
        },
        "standup.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["**/node_modules/**", "**/.git/**"],
          "description": "List of glob patterns to ignore during tracking"
        },
        "standup.enableTerminalTracking": {
          "type": "boolean",
          "default": true,
          "description": "Enable terminal command tracking (tracks commands executed in integrated terminals)"
        },
        "standup.terminalTrackingMode": {
          "type": "string",
          "enum": ["integrated", "history", "both"],
          "default": "integrated",
          "description": "Terminal tracking mode: 'integrated' (VS Code terminals), 'history' (shell history files), or 'both'"
        },
        "standup.dataRetentionDays": {
          "type": "integer",
          "default": 30,
          "minimum": 1,
          "maximum": 365,
          "description": "Number of days to retain activity data before automatic cleanup"
        },
        "standup.autoCleanupEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic cleanup of old activity data"
        },
        "standup.cleanupIntervalDays": {
          "type": "integer",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "Number of days between automatic cleanup runs"
        }
      }
    },
    "commands": [
      {
        "command": "standup.generate",
        "title": "Standup: Generate Daily Summary"
      },
      {
        "command": "standup.setApiKey",
        "title": "Standup: Set Gemini API Key"
      },
      {
        "command": "standup.setNotionToken",
        "title": "Standup: Set Notion API Token"
      },
      {
        "command": "standup.setJiraToken",
        "title": "Standup: Set Jira API Token"
      },
      {
        "command": "standup.exportToNotion",
        "title": "Standup: Export to Notion"
      },
      {
        "command": "standup.exportToJira",
        "title": "Standup: Post to Jira"
      },
      {
        "command": "standup.viewHistory",
        "title": "Standup: View History"
      },
      {
        "command": "standup.viewAnalytics",
        "title": "Standup: View Analytics Dashboard"
      },
      {
        "command": "standup.toggleTracking",
        "title": "Standup: Pause/Resume Tracking"
      },
      {
        "command": "standup.previewData",
        "title": "Standup: Preview Raw Data"
      },
      {
        "command": "standup.generateWeeklyDigest",
        "title": "Standup: Generate Weekly Digest"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}