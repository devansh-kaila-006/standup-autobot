{
  "name": "standup-autobot",
  "displayName": "Standup Autobot",
  "description": "Silently tracks developer activity and generates daily standup summaries using local LLMs.",
  "version": "2.0.1",
  "publisher": "devansh-kaila-006",
  "license": "LICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/devansh-kaila-006/standup-autobot"
  },
  "bugs": {
    "url": "https://github.com/devansh-kaila-006/standup-autobot/issues"
  },
  "homepage": "https://github.com/devansh-kaila-006/standup-autobot#readme",
  "keywords": [
    "standup",
    "productivity",
    "ai",
    "gemini",
    "tracking"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:standupAutobot.sidePanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Standup Autobot",
      "properties": {
        "standup.triggerTime": {
          "type": "string",
          "default": "09:00",
          "description": "Daily time to trigger standup summary generation (HH:MM)"
        },
        "standup.activityDuration": {
          "type": "integer",
          "default": 24,
          "description": "Number of hours of activity to include in the summary"
        },
        "standup.customPrompt": {
          "type": "string",
          "default": "",
          "description": "Additional instructions to append to the Gemini prompt (e.g., 'Mention JIRA tickets')"
        },
        "standup.tone": {
          "type": "string",
          "enum": [
            "brief",
            "detailed",
            "casual",
            "formal"
          ],
          "default": "casual",
          "description": "The tone of the generated standup summary"
        },
        "standup.outputLanguage": {
          "type": "string",
          "default": "English",
          "description": "The language in which the summary should be generated"
        },
        "standup.notionPageId": {
          "type": "string",
          "default": "",
          "description": "The Notion Page ID where standups should be appended"
        },
        "standup.jiraDomain": {
          "type": "string",
          "default": "",
          "description": "Your Jira domain (e.g., 'company' for company.atlassian.net)"
        },
        "standup.jiraEmail": {
          "type": "string",
          "default": "",
          "description": "Email for Jira API authentication"
        },
        "standup.jiraIssueKey": {
          "type": "string",
          "default": "",
          "description": "Default Jira Issue Key to post comments to (can be overridden during export)"
        },
        "standup.ignorePatterns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": ["**/node_modules/**", "**/.git/**"],
          "description": "List of glob patterns to ignore during tracking"
        },
        "standup.enableTerminalTracking": {
          "type": "boolean",
          "default": true,
          "description": "Enable terminal command tracking (tracks commands executed in integrated terminals)"
        },
        "standup.terminalTrackingMode": {
          "type": "string",
          "enum": ["integrated", "history", "both"],
          "default": "integrated",
          "description": "Terminal tracking mode: 'integrated' (VS Code terminals), 'history' (shell history files), or 'both'"
        },
        "standup.dataRetentionDays": {
          "type": "integer",
          "default": 30,
          "minimum": 1,
          "maximum": 365,
          "description": "Number of days to retain activity data before automatic cleanup"
        },
        "standup.autoCleanupEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable automatic cleanup of old activity data"
        },
        "standup.cleanupIntervalDays": {
          "type": "integer",
          "default": 7,
          "minimum": 1,
          "maximum": 30,
          "description": "Number of days between automatic cleanup runs"
        },
        "standup.aiProvider": {
          "type": "string",
          "enum": ["gemini", "openai", "claude", "local"],
          "default": "gemini",
          "description": "AI provider for standup generation"
        },
        "standup.fallbackProvider": {
          "type": "string",
          "enum": ["gemini", "openai", "claude", "local"],
          "default": "local",
          "description": "Fallback AI provider if primary fails"
        },
        "standup.openaiModel": {
          "type": "string",
          "default": "gpt-4",
          "description": "OpenAI model to use"
        },
        "standup.openaiTemperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "OpenAI temperature (0.0-1.0)"
        },
        "standup.openaiMaxTokens": {
          "type": "integer",
          "default": 1000,
          "description": "OpenAI max tokens"
        },
        "standup.claudeModel": {
          "type": "string",
          "default": "claude-3-5-sonnet-20241022",
          "description": "Anthropic Claude model to use"
        },
        "standup.claudeTemperature": {
          "type": "number",
          "default": 0.7,
          "minimum": 0,
          "maximum": 1,
          "description": "Claude temperature (0.0-1.0)"
        },
        "standup.claudeMaxTokens": {
          "type": "integer",
          "default": 1000,
          "description": "Claude max tokens"
        },
        "standup.localLlmBaseUrl": {
          "type": "string",
          "default": "http://localhost:11434",
          "description": "Ollama base URL for local LLM"
        },
        "standup.localLlmModel": {
          "type": "string",
          "default": "llama2",
          "description": "Local LLM model to use"
        },
        "standup.locale": {
          "type": "string",
          "enum": ["en", "es", "fr", "de", "ja", "zh-CN", "zh-TW", "pt-BR", "ru", "ar"],
          "default": "en",
          "description": "Interface language"
        },
        "standup.apiTimeout": {
          "type": "integer",
          "default": 30000,
          "minimum": 1000,
          "maximum": 120000,
          "description": "API request timeout in milliseconds"
        },
        "standup.apiRetryAttempts": {
          "type": "integer",
          "default": 3,
          "minimum": 0,
          "maximum": 10,
          "description": "Number of retry attempts for failed API calls"
        },
        "standup.apiRetryDelay": {
          "type": "integer",
          "default": 1000,
          "minimum": 100,
          "maximum": 10000,
          "description": "Delay between API retry attempts in milliseconds"
        },
        "standup.dashboardRefreshInterval": {
          "type": "integer",
          "default": 5000,
          "minimum": 1000,
          "maximum": 60000,
          "description": "Dashboard auto-refresh interval in milliseconds"
        },
        "standup.historyPageSize": {
          "type": "integer",
          "default": 20,
          "minimum": 5,
          "maximum": 100,
          "description": "Number of items to load per page in history view"
        },
        "standup.maxCacheSize": {
          "type": "integer",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum number of items to keep in API response cache"
        },
        "standup.cacheTTL": {
          "type": "integer",
          "default": 300000,
          "minimum": 60000,
          "maximum": 3600000,
          "description": "Cache time-to-live in milliseconds"
        },
        "standup.rateLimitRequestsPerMinute": {
          "type": "integer",
          "default": 60,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum API requests per minute"
        },
        "standup.rateLimitBurstSize": {
          "type": "integer",
          "default": 10,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum burst size for rate limiting"
        },
        "standup.maxFileSize": {
          "type": "integer",
          "default": 10485760,
          "minimum": 102400,
          "maximum": 104857600,
          "description": "Maximum file size to track in bytes (default: 10MB)"
        },
        "standup.notificationRetentionDays": {
          "type": "integer",
          "default": 30,
          "minimum": 1,
          "maximum": 365,
          "description": "Number of days to retain notifications"
        },
        "standup.maxNotificationsPerDay": {
          "type": "integer",
          "default": 50,
          "minimum": 10,
          "maximum": 500,
          "description": "Maximum notifications per day before auto-cleanup"
        },
        "standup.githubApiUrl": {
          "type": "string",
          "default": "https://api.github.com",
          "description": "GitHub API base URL"
        },
        "standup.notionApiUrl": {
          "type": "string",
          "default": "https://api.notion.com",
          "description": "Notion API base URL"
        },
        "standup.jiraApiBaseUrl": {
          "type": "string",
          "default": "https://{domain}.atlassian.net",
          "description": "Jira API base URL pattern (use {domain} as placeholder)"
        },
        "standup.slackApiUrl": {
          "type": "string",
          "default": "https://slack.com/api",
          "description": "Slack API base URL"
        },
        "standup.teamsAuthorityUrl": {
          "type": "string",
          "default": "https://login.microsoftonline.com",
          "description": "Microsoft Teams authority URL for OAuth"
        },
        "standup.teamsGraphApiUrl": {
          "type": "string",
          "default": "https://graph.microsoft.com",
          "description": "Microsoft Graph API base URL for Teams"
        },
        "standup.azureDevOpsApiUrl": {
          "type": "string",
          "default": "https://dev.azure.com",
          "description": "Azure DevOps API base URL"
        },
        "standup.harvestApiUrl": {
          "type": "string",
          "default": "https://api.harvestapp.com",
          "description": "Harvest API base URL"
        },
        "standup.togglApiUrl": {
          "type": "string",
          "default": "https://api.track.toggl.com",
          "description": "Toggl API base URL"
        },
        "standup.cdnReactUrl": {
          "type": "string",
          "default": "https://unpkg.com/react@18/umd/react.production.min.js",
          "description": "CDN URL for React library"
        },
        "standup.cdnReactDOMUrl": {
          "type": "string",
          "default": "https://unpkg.com/react-dom@18/umd/react-dom.production.min.js",
          "description": "CDN URL for React DOM library"
        },
        "standup.cdnBabelUrl": {
          "type": "string",
          "default": "https://unpkg.com/@babel/standalone/babel.min.js",
          "description": "CDN URL for Babel standalone"
        },
        "standup.cdnTailwindUrl": {
          "type": "string",
          "default": "https://cdn.tailwindcss.com",
          "description": "CDN URL for Tailwind CSS"
        },
        "standup.cdnMarkedUrl": {
          "type": "string",
          "default": "https://cdn.jsdelivr.net/npm/marked/marked.min.js",
          "description": "CDN URL for Marked markdown parser"
        },
        "standup.cdnChartJsUrl": {
          "type": "string",
          "default": "https://cdn.jsdelivr.net/npm/chart.js",
          "description": "CDN URL for Chart.js library"
        },
        "standup.defaultImagePlaceholder": {
          "type": "string",
          "default": "https://adaptivecards.io/content/cats/1.png",
          "description": "Default placeholder image URL"
        }
      }
    },
    "commands": [
      {
        "command": "standup.generate",
        "title": "Standup: Generate Daily Summary"
      },
      {
        "command": "standup.setApiKey",
        "title": "Standup: Set Gemini API Key"
      },
      {
        "command": "standup.setNotionToken",
        "title": "Standup: Set Notion API Token"
      },
      {
        "command": "standup.setJiraToken",
        "title": "Standup: Set Jira API Token"
      },
      {
        "command": "standup.exportToNotion",
        "title": "Standup: Export to Notion"
      },
      {
        "command": "standup.exportToJira",
        "title": "Standup: Post to Jira"
      },
      {
        "command": "standup.viewHistory",
        "title": "Standup: View History"
      },
      {
        "command": "standup.toggleTracking",
        "title": "Standup: Pause/Resume Tracking"
      },
      {
        "command": "standup.previewData",
        "title": "Standup: Preview Raw Data"
      },
      {
        "command": "standup.generateWeeklyDigest",
        "title": "Standup: Generate Weekly Digest"
      },
      {
        "command": "standup.generateStandup",
        "title": "Standup: Generate Standup"
      },
      {
        "command": "standup.copyToClipboard",
        "title": "Standup: Copy to Clipboard"
      },
      {
        "command": "standup.export",
        "title": "Standup: Export"
      },
      {
        "command": "standup.showHistory",
        "title": "Standup: Show History"
      },
      {
        "command": "standup.dataAudit",
        "title": "Standup: Data Audit"
      },
      {
        "command": "standup.showNotifications",
        "title": "Standup: Show Notifications"
      },
      {
        "command": "standup.markNotificationsRead",
        "title": "Standup: Mark All Notifications Read"
      },
      {
        "command": "standup.configureSettings",
        "title": "Standup: Configure Settings"
      },
      {
        "command": "standup.testJiraConnection",
        "title": "Standup: Test Jira Connection"
      },
      {
        "command": "standup.testGitHubConnection",
        "title": "Standup: Test GitHub Connection"
      },
      {
        "command": "standup.testSlackConnection",
        "title": "Standup: Test Slack Connection"
      },
      {
        "command": "standup.setOpenaiApiKey",
        "title": "Standup: Set OpenAI API Key"
      },
      {
        "command": "standup.setClaudeApiKey",
        "title": "Standup: Set Claude API Key"
      },
      {
        "command": "standup.configureShortcuts",
        "title": "Standup: Configure Keyboard Shortcuts"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "standupAutobot-activitybar",
          "title": "Standup Autobot",
          "icon": "media/icons/dashboard.svg"
        }
      ]
    },
    "views": {
      "standupAutobot-activitybar": [
        {
          "id": "standupAutobot.sidePanel",
          "name": "Dashboard",
          "type": "webview",
          "contextualTitle": "Standup Dashboard"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ --incremental false",
    "watch": "tsc -watch -p ./",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.45.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  }
}